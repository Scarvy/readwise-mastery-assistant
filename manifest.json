{
  "manifest_version": 3,
  "name": "Readwise Mastery Assistant",
  "version": "0.2.0",
  "icons": {
    "128": "public/icons/icon128.png"
  },
  "description": "AI-assisted Q&A flashcard suggestions for Readwise's Mastery card editor.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://readwise.io/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://readwise.io/dailyreview*",
        "https://readwise.io/review/*",
        "https://readwise.io/reviews/*",
        "https://readwise.io/bookreview/*",
        "https://readwise.io/master/due*",
        "https://readwise.io/master/all*"
      ],
      "js": ["src/content/content.js"],
      "css": ["src/content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "src/settings/settings.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "src/popup/popup.html"
  }
}
